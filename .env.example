# MIDNIGHT TAPE — environment variables
# Copy to .env (NEVER commit .env)
# All keys are public/anon — server-only secrets stay in Supabase Edge Function env.

# Supabase (shared project across the trackmarkete ecosystem)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Journal identity — UUID of this journal in the `journals` table.
# Used by JournalAccessGate to check entitlement.
VITE_JOURNAL_ID=
